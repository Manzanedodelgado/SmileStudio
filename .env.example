# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://smilestudio:smilestudio_secret@localhost:5432/smilestudio?schema=public
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── IA (Gemini API) ────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── WhatsApp (Evolution API) ───────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# ─── Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=smilestudio-medical

# ─── Backup ──────────────────────────────────────────────
BACKUP_GPG_RECIPIENT=backup@rubiogarcia.dental
BACKUP_NAS_PATH=/mnt/nas/backups
