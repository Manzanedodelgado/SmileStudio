    "rpcs_supabase": {
        "descripcion": "Funciones PostgreSQL personalizadas accesibles via REST v1/rpc/",
        "rpc": {
            "app_login": {
                "servicio": "services/auth.service.ts",
                "entrada": {
                    "p_email": "string",
                    "p_password": "string"
                },
                "salida": {
                    "token": "string",
                    "expires_at": "string",
                    "user": "object"
                },
                "vistas_consumidoras": [
                    "views/Login.tsx"
                ],
                "notas": "Login custom sin GoTrue — bcrypt server-side"
            },
            "validate_token": {
                "servicio": "services/auth.service.ts",
                "entrada": {
                    "p_token": "string"
                },
                "salida": {
                    "valid": "boolean",
                    "user": "object"
                },
                "vistas_consumidoras": [
                    "context/AuthContext.tsx"
                ],
                "notas": "Validación TTL server-side. Se llama en cada carga de la app."
            },
            "revoke_token": {
                "servicio": "services/auth.service.ts",
                "entrada": {
                    "p_token": "string"
                },
                "salida": {},
                "vistas_consumidoras": [
                    "context/AuthContext.tsx (logout)"
                ],
                "notas": "Logout real — invalida el token en la BD"
            },
            "reserve_slot": {
                "servicio": "services/citas.service.ts",
                "entrada": {
                    "p_num_pac": "string|null",
                    "p_nombre": "string",
                    "p_fecha": "date",
                    "p_hora": "time",
                    "p_duracion": "int",
                    "p_tratamiento": "string",
                    "p_doctor": "string",
                    "p_gabinete": "string",
                    "p_notas": "string"
                },
                "salida": {
                    "id": "uuid"
                },
                "vistas_consumidoras": [
                    "views/Agenda.tsx"
                ],
                "notas": "Locking pesimista — SELECT FOR UPDATE + INSERT atómico"
            },
            "upsert_odontograma": {
                "servicio": "services/odontograma.service.ts",
                "entrada": {
                    "p_num_pac": "string",
                    "p_datos": "json"
                },
                "salida": {},
                "vistas_consumidoras": [
                    "components/pacientes/Odontograma.tsx"
                ],
                "notas": "ON CONFLICT DO UPDATE — elimina race condition SELECT-then-INSERT"
            }
        }
    },
