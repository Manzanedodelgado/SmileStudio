// ==========================================
// AUTENTICACIÓN & USUARIOS (SMILESTUDIO)
// ==========================================

enum UserRole {
  admin
  doctor
  hygienist
  reception
  accounting
  auxiliary
}

model User {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(auxiliary)
  avatar    String?
  specialty String?
  active    Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

