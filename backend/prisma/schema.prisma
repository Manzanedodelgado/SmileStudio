  @@map("gest_proveedores")
}

model GestFacturasEmail {
  gmailMessageId   String   @id @map("gmail_message_id")
  proveedorExtraido String? @map("proveedor_extraido")
  proveedorId      String?  @map("proveedor_id") @db.Uuid
  numeroFactura    String?  @map("numero_factura")
  fechaFactura     DateTime? @map("fecha_factura") @db.Date
  baseImponible    Decimal?  @map("base_imponible") @db.Decimal(10, 2)
  ivaPct           Decimal?  @map("iva_pct") @db.Decimal(5, 2)
  total            Decimal?  @map("total") @db.Decimal(10, 2)
  archivoPdfUrl    String?   @map("archivo_pdf_url")
  estado           String?   @default("pendiente")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  proveedor        GestProveedores? @relation(fields: [proveedorId], references: [id])
  movimientosBancarios GestMovimientosBancarios[]

  @@map("gest_facturas_email")
}

model GestFacturasEmitidas {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numeroSerie      String   @unique @map("numero_serie")
  numPac           String?  @map("num_pac")
  nifCliente       String   @map("nif_cliente")
  nombreCliente    String   @map("nombre_cliente")
  concepto         String
  baseImponible    Decimal  @map("base_imponible") @db.Decimal(10, 2)
  ivaPct           Decimal? @default(0) @map("iva_pct") @db.Decimal(5, 2)
  total            Decimal  @map("total") @db.Decimal(10, 2)
  fechaEmision     DateTime @map("fecha_emision") @db.Date
  estadoPago       String?  @default("pendiente") @map("estado_pago")
  verifactuEstado  String?  @default("no_enviado") @map("verifactu_estado")
  verifactuHash    String?  @map("verifactu_hash")

  movimientosBancarios GestMovimientosBancarios[]

  @@map("gest_facturas_emitidas")
}

model GestMovimientosBancarios {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ibanCuenta       String   @map("iban_cuenta")
  fechaOperacion   DateTime @map("fecha_operacion") @db.Date
  conceptoBanco    String   @map("concepto_banco")
  importe          Decimal  @db.Decimal(10, 2)
  saldoPosterior   Decimal? @map("saldo_posterior") @db.Decimal(10, 2)
  estadoConcil     String?  @default("abierto") @map("estado_concil")
  fEmitidaId       String?  @map("f_emitida_id") @db.Uuid
  fRecibidaId      String?  @map("f_recibida_id")

  facturaEmitida   GestFacturasEmitidas? @relation(fields: [fEmitidaId], references: [id])
  facturaRecibida  GestFacturasEmail?    @relation(fields: [fRecibidaId], references: [gmailMessageId])

  @@map("gest_movimientos_bancarios")
}

model GestModelosFiscales {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelo           String
  ejercicio        Int
  periodo          String
  estado           String?  @default("borrador")
  fechaLimite      DateTime @map("fecha_limite") @db.Date
  cuotaResultante  Decimal? @map("cuota_resultante") @db.Decimal(10, 2)
  archivoJustif    String?  @map("archivo_justif")

  @@unique([modelo, ejercicio, periodo])
  @@map("gest_modelos_fiscales")
}

// ==========================================
// MÓDULO CLÍNICO — SMILESTUDIO NATIVE
// ==========================================

model Patient {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  dni          String?   @unique
  phone        String
  email        String?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  address      String?
  city         String?
  postalCode   String?   @map("postal_code")
  medicalNotes String?   @map("medical_notes")
  allergies    String?
  medications  String?
  bloodType    String?   @map("blood_type")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  odontogram      OdontogramEntry[]

  @@map("patients")
}

model Appointment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @map("patient_id") @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  date      DateTime  @db.Date
  time      String
  duration  Int       @default(30)
  status    String    @default("scheduled")
  treatment String?
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  patient   Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([date])
  @@map("appointments")
}

model ClinicalRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  date        DateTime @default(now())
  type        String   @default("visit")
  title       String
  content     String
  treatments  Json?    @default("[]")
  attachments Json?    @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient     Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([date(sort: Desc)])
  @@map("clinical_records")
}

model OdontogramEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  toothNumber Int      @map("tooth_number")
  status      String   @default("healthy")
  faces       Json?    @default("{}")
  notes       String?
  userId      String?  @map("user_id") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient     Patient  @relation(fields: [patientId], references: [id])

  @@unique([patientId, toothNumber])
  @@map("odontogram_entries")
}

model Treatment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String?  @unique
  category    String
  price       Decimal  @db.Decimal(10, 2)
  duration    Int      @default(30)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("treatments")
}

// ==========================================
// MÓDULO IA & AUTOMATIZACIONES
// ==========================================

model Automation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  enabled     Boolean  @default(true)
  trigger     String
  canal       String   @default("whatsapp")
  steps       Json     @default("[]")
  successRate Int      @default(0) @map("success_rate")
  executions  Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([enabled])
  @@index([trigger])
  @@map("automations")
}

model AIConfig {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentName        String   @default("IA Dental") @map("agent_name")
  language         String   @default("es")
  welcomeMsg       String   @default("¡Hola! ¿En qué puedo ayudarte?") @map("welcome_msg")
  tone             Json     @default("{\"empathy\":4,\"proactivity\":3,\"formality\":\"semiformal\"}")
  knowledge        String[] @default([])
  escalationRules  Json     @default("[]") @map("escalation_rules")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("ai_config")
}

model ConversationHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String
  patientId String?  @map("patient_id") @db.Uuid
  messages  Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime @map("expires_at") @db.Timestamptz

  @@index([phone])
  @@index([expiresAt])
  @@map("conversation_history")
}

// ─── Inventario ───────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  sku         String   @unique
  category    String   @default("Desechable")
  minReorder  Int      @default(10) @map("min_reorder")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  lots      Lot[]
  movements StockMovement[]

  @@map("products")
}

model Lot {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  lotNumber   String    @map("lot_number")
  expiryDate  DateTime? @map("expiry_date") @db.Timestamptz
  quantity    Int       @default(0)
  location    String    @default("Almacén Central")
  status      String    @default("OK")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([productId])
  @@map("lots")
}

model StockMovement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id])
  lotId     String?  @map("lot_id") @db.Uuid
  type      String   // 'in' | 'out' | 'adjustment'
  quantity  Int
  reason    String?
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}
